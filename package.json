{
  "name": "branch-consolidator",
  "version": "2.0.0",
  "description": "Angular codebase consolidation tool with watertight dependency detection and interactive migration",
  "main": "dist/server/index.js",
  "bin": {
    "consolidate": "./dist/server/index.js"
  },
  "scripts": {
    "build": "tsc",
    "start": "node dist/server/index.js",
    "serve": "npm run build && node dist/server/index.js",
    "verify": "npm run build && node dist/verify.js",
    "report": "npm run build && node dist/demo-report.js",
    "test": "jest",
    "test:fixture": "npm run build && node dist/server/index.js --project ./test-fixture --port 3000",
    "init:fixture": "cd test-fixture && git init && git add -A && git commit -m 'Initial commit'"
  },
  "dependencies": {
    "commander": "^11.1.0",
    "diff": "^5.1.0",
    "express": "^5.2.1",
    "glob": "^10.3.10",
    "ts-morph": "^21.0.1",
    "ws": "^8.20.0"
  },
  "devDependencies": {
    "@types/diff": "^5.0.8",
    "@types/express": "^5.0.6",
    "@types/jest": "^29.5.11",
    "@types/node": "^20.10.0",
    "@types/ws": "^8.18.1",
    "jest": "^29.7.0",
    "ts-jest": "^29.1.1",
    "typescript": "^5.3.2"
  }
}
