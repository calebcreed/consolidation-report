{
  "name": "webpos-consolidator",
  "version": "2.0.0",
  "description": "Angular codebase consolidation analyzer with watertight dependency detection",
  "main": "dist/index.js",
  "bin": {
    "consolidate": "./dist/index.js"
  },
  "scripts": {
    "build": "tsc",
    "start": "node dist/index.js",
    "analyze": "npm run build && npm start",
    "verify": "npm run build && node dist/v2/verify.js",
    "test": "jest",
    "test:v2": "jest src/v2/"
  },
  "dependencies": {
    "ts-morph": "^21.0.1",
    "diff": "^5.1.0",
    "commander": "^11.1.0",
    "glob": "^10.3.10"
  },
  "devDependencies": {
    "@types/node": "^20.10.0",
    "@types/diff": "^5.0.8",
    "@types/jest": "^29.5.11",
    "jest": "^29.7.0",
    "ts-jest": "^29.1.1",
    "typescript": "^5.3.2"
  }
}
