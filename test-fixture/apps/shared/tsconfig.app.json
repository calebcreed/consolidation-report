{
  "compilerOptions": {
    "baseUrl": "src",
    "outDir": "../../dist/out-tsc",
    "types": [],
    "paths": {
      "@app/*": ["app/*"],
      "@appCommon/*": ["app/modules/+appCommon/*"],
      "@assets/*": ["assets/*"],
      "@auth/*": ["app/modules/+auth/*"],
      "@checklist/*": ["app/modules/+checklist/*"],
      "@core/*": ["app/core/*"],
      "@env/*": ["environments/*"],
      "@operation/*": ["app/modules/+operation/*"],
      "@paymentModule/*": ["app/modules/+paymentModule/*"],
      "@sharedModule/*": ["app/shared/*"],
      "@splitModule/*": ["app/modules/+splitModule/*"]
    }
  },
  "angularCompilerOptions": {
    "enableIvy": true,
    "skipLibCheck": true
  },
  "files": ["src/main.ts", "src/polyfills.ts"],
  "include": ["src/**/*.ts", "src/**/*.d.ts"],
  "exclude": [
    "src/**/*.spec.ts",
    "src/**/*.worker.ts"
  ]
}
